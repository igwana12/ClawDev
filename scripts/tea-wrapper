#!/bin/bash
# tea 包装脚本
# 如果智能体工作目录下存在 gitea-cli.conf 目录，直接将其作为 XDG_CONFIG_HOME
# 否则从默认配置目录复制一份到工作目录下（tea 遵循 XDG，配置位于 $XDG_CONFIG_HOME/tea）

REAL_TEA=/home/linuxbrew/.linuxbrew/bin/tea
DEFAULT_TEA_DIR="$HOME/.config/tea"
WORKSPACE_CONF_DIR="$PWD/gitea-cli.conf"
WORKSPACE_TEA_DIR="$WORKSPACE_CONF_DIR/tea"

if [ ! -d "$WORKSPACE_CONF_DIR" ]; then
    if [ -d "$DEFAULT_TEA_DIR" ]; then
        # 已有默认登录配置，复制到工作区隔离
        mkdir -p "$WORKSPACE_CONF_DIR"
        cp -r "$DEFAULT_TEA_DIR" "$WORKSPACE_TEA_DIR"
    else
        # 全新环境，创建空配置目录等待 tea login 初始化
        mkdir -p "$WORKSPACE_TEA_DIR"
    fi
fi

XDG_CONFIG_HOME="$WORKSPACE_CONF_DIR" exec "$REAL_TEA" "$@"