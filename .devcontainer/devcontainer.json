{
  "name": "ClawDev",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "openclaw-gateway",
  "workspaceFolder": "/app/ClawDev",
  "forwardPorts": [18789, 3000],
  "portsAttributes": {
    "18789": {
      "label": "OpenClaw Gateway",
      "onAutoForward": "openPreview"
    },
    "3000": {
      "label": "Gitea",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-ceintl.vscode-language-pack-zh-hans",
        "oderwat.indent-rainbow",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "ms-python.debugpy",
        "ms-python.isort",
        "ms-python.pylint",
        "ms-python.black-formatter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/app/ClawDev/.venv/bin/python",
        "python.linting.enabled": true
      }
    }
  },
  "postCreateCommand": "cd /app/ClawDev && uv sync --dev",
  "remoteUser": "node"
}
